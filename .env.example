GITHUB_APP_ID=                # GitHub App ID from Developer Settings
GITHUB_WEBHOOK_SECRET=        # Secret used to verify GitHub webhooks
GITHUB_INSTALLATION_ID=       # GitHub App installation ID for repo access
GROQ_API_KEY=                 # API key from Groq Console
GITHUB_PRIVATE_KEY=           # Full GitHub App private key
DATABASE_URL=                 # PostgreSQL URL (prod) / optional locally